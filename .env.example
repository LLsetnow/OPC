# ── 智谱AI API 配置（ASR 用） ───────────────────────────────────
# 必填：在 https://open.bigmodel.cn/ 注册获取
ZHIPU_API_KEY=your_api_key_here

# API Base URL（默认使用智谱官方地址，一般不需要修改）
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ── ASR 模型配置 ─────────────────────────────────────────────────
# ASR 模型名称（默认 glm-asr-2512）
ASR_MODEL=glm-asr-2512

# ── LLM 总结模型配置 ─────────────────────────────────────────────
# 用于生成内容总结的 LLM 模型
# 如需使用与 ASR 不同的 API 服务，可单独配置 LLM_API_KEY 和 LLM_BASE_URL
# 未设置时回退到 ZHIPU_API_KEY / ZHIPU_BASE_URL
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM 模型名称（默认 glm-4-flash）
# 可选: glm-4-flash, glm-4, glm-4-plus, glm-4-long 等
LLM_MODEL=glm-4-flash

# ── Bilibili 下载配置 ────────────────────────────────────────────
# yt-dlp cookies 文件路径（可选，用于下载需要登录的视频）
# 使用浏览器扩展 "Get cookies.txt LOCALLY" 在登录 Bilibili 后导出
# YT_DLP_COOKIES=./cookies.txt

# ── 视觉模型 API 配置 ──────────────────────────────────────────
# 用于图片理解（opc img），优先使用智谱官方 API（支持视觉模型）
# 未设置时回退到 ZHIPU_API_KEY / ZHIPU_BASE_URL
#VISION_API_KEY=your_vision_api_key_here
#VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
